module mysql_integration_test;
import lib/MySQL-Interact;

fn test_pass(name: str) -> void {
    print_raw("  [PASS] " + name + "\n");
}

fn test_fail(name: str, detail: str) -> void {
    print_raw("  [FAIL] " + name + ": " + detail + "\n");
}

fn main(argc: i32, argv: u64) -> i32 {
    let fails: i32 = 0;
    print_raw("=== MySQL-Interact Integration Tests ===\n\n");

    // Connect
    print_raw("--- Connection ---\n");
    let fd: i32 = mysql_connect_local(3307, "root", "testpass123", "testdb");
    if (fd < 0) {
        test_fail("connect", "fd < 0");
        return 1;
    }
    test_pass("connect");

    // Ping
    if (mysql_ping(fd)) {
        test_pass("ping");
    } else {
        test_fail("ping", "returned false");
        fails = fails + 1;
    }

    // Server info
    print_raw("\n--- Server Info ---\n");
    let ver: str = mysql_server_version(fd);
    if (len(ver) > 0) {
        test_pass("server_version: " + ver);
    } else {
        test_fail("server_version", "empty");
        fails = fails + 1;
    }

    let cur_db: str = mysql_current_database(fd);
    if (cur_db == "testdb") {
        test_pass("current_database = testdb");
    } else {
        test_fail("current_database", "got: " + cur_db);
        fails = fails + 1;
    }

    let cur_user: str = mysql_current_user(fd);
    if (len(cur_user) > 0) {
        test_pass("current_user: " + cur_user);
    } else {
        test_fail("current_user", "empty");
        fails = fails + 1;
    }

    // DDL
    print_raw("\n--- DDL ---\n");
    let drop_r: str = mysql_query(fd, "DROP TABLE IF EXISTS test_users");
    if (!mysql_is_error(drop_r)) {
        test_pass("drop table");
    } else {
        test_fail("drop table", mysql_error_msg(drop_r));
        fails = fails + 1;
    }

    let create_r: str = mysql_query(fd, "CREATE TABLE test_users (id INT AUTO_INCREMENT PRIMARY KEY, name VARCHAR(100) NOT NULL, email VARCHAR(200), age INT)");
    if (!mysql_is_error(create_r)) {
        test_pass("create table");
    } else {
        test_fail("create table", mysql_error_msg(create_r));
        fails = fails + 1;
    }

    if (mysql_table_exists(fd, "test_users")) {
        test_pass("table_exists");
    } else {
        test_fail("table_exists", "returned false");
        fails = fails + 1;
    }

    // INSERT with escaping
    print_raw("\n--- INSERT (escaped) ---\n");
    let name1: str = "Alice O'Brien";
    let email1: str = "alice@example.com";
    let sql1: str = "INSERT INTO test_users (name, email, age) VALUES (" + mysql_quote(name1) + ", " + mysql_quote(email1) + ", 30)";
    let ins1: str = mysql_query(fd, sql1);
    if (mysql_is_ok(ins1)) {
        test_pass("insert escaped");
        let aid: i64 = mysql_affected_rows(ins1);
        if (aid == 1) {
            test_pass("affected_rows = 1");
        } else {
            test_fail("affected_rows", i64_to_str(aid));
            fails = fails + 1;
        }
    } else {
        test_fail("insert escaped", mysql_error_msg(ins1));
        fails = fails + 1;
    }

    // INSERT with parameterized query builder
    print_raw("\n--- INSERT (parameterized builder) ---\n");
    let sql2: str = "INSERT INTO test_users (name, email, age) VALUES (?, ?, ?)";
    sql2 = mysql_set_param_str(sql2, "Bob \"The Builder\"");
    sql2 = mysql_set_param_str(sql2, "bob@example.com");
    sql2 = mysql_set_param_i32(sql2, 25);
    let ins2: str = mysql_query(fd, sql2);
    if (mysql_is_ok(ins2)) {
        test_pass("insert parameterized");
    } else {
        test_fail("insert parameterized", mysql_error_msg(ins2));
        fails = fails + 1;
    }

    // SQL injection attempt
    print_raw("\n--- SQL Injection Prevention ---\n");
    let evil: str = "'; DROP TABLE test_users; --";
    let sql_evil: str = "INSERT INTO test_users (name, email, age) VALUES (?, ?, ?)";
    sql_evil = mysql_set_param_str(sql_evil, evil);
    sql_evil = mysql_set_param_str(sql_evil, "evil@hacker.com");
    sql_evil = mysql_set_param_i32(sql_evil, 99);
    let ins_evil: str = mysql_query(fd, sql_evil);
    if (mysql_is_ok(ins_evil)) {
        test_pass("injection attempt safely inserted");
    } else {
        test_fail("injection insert", mysql_error_msg(ins_evil));
        fails = fails + 1;
    }

    // Verify table still exists after injection attempt
    if (mysql_table_exists(fd, "test_users")) {
        test_pass("table survives injection");
    } else {
        test_fail("table survives injection", "table was dropped!");
        fails = fails + 1;
    }

    // SELECT
    print_raw("\n--- SELECT ---\n");
    let sel: str = mysql_query(fd, "SELECT id, name, email, age FROM test_users ORDER BY id");
    if (mysql_is_result_set(sel)) {
        test_pass("select returns result set");

        let ncols: i32 = mysql_num_cols(sel);
        if (ncols == 4) {
            test_pass("num_cols = 4");
        } else {
            test_fail("num_cols", i32_to_str(ncols));
            fails = fails + 1;
        }

        let nrows: i32 = mysql_num_rows(sel);
        if (nrows == 3) {
            test_pass("num_rows = 3");
        } else {
            test_fail("num_rows", i32_to_str(nrows));
            fails = fails + 1;
        }

        // Check column names
        let c0: str = mysql_col_name(sel, 0);
        if (c0 == "id") {
            test_pass("col_name(0) = id");
        } else {
            test_fail("col_name(0)", c0);
            fails = fails + 1;
        }

        let c1: str = mysql_col_name(sel, 1);
        if (c1 == "name") {
            test_pass("col_name(1) = name");
        } else {
            test_fail("col_name(1)", c1);
            fails = fails + 1;
        }

        // Check values
        let v_name0: str = mysql_get(sel, 0, 1);
        if (str_contains(v_name0, "Alice")) {
            test_pass("row0.name contains Alice");
        } else {
            test_fail("row0.name", v_name0);
            fails = fails + 1;
        }

        let v_name2: str = mysql_get(sel, 2, 1);
        if (str_contains(v_name2, "DROP TABLE")) {
            test_pass("injection string stored safely");
        } else {
            test_fail("injection stored", v_name2);
            fails = fails + 1;
        }

        let v_age0: str = mysql_get(sel, 0, 3);
        if (v_age0 == "30") {
            test_pass("row0.age = 30");
        } else {
            test_fail("row0.age", v_age0);
            fails = fails + 1;
        }
    } else {
        test_fail("select", "not a result set");
        fails = fails + 1;
    }

    // UPDATE
    print_raw("\n--- UPDATE ---\n");
    let upd: str = mysql_query(fd, "UPDATE test_users SET age = 31 WHERE name = " + mysql_quote("Alice O'Brien"));
    if (mysql_is_ok(upd)) {
        test_pass("update");
        let aff: i64 = mysql_affected_rows(upd);
        if (aff == 1) {
            test_pass("update affected_rows = 1");
        } else {
            test_fail("update affected", i64_to_str(aff));
            fails = fails + 1;
        }
    } else {
        test_fail("update", mysql_error_msg(upd));
        fails = fails + 1;
    }

    // Transactions
    print_raw("\n--- Transactions ---\n");
    let begin_r: str = mysql_begin(fd);
    if (!mysql_is_error(begin_r)) {
        test_pass("begin transaction");
    } else {
        test_fail("begin", mysql_error_msg(begin_r));
        fails = fails + 1;
    }

    mysql_query(fd, "INSERT INTO test_users (name, email, age) VALUES ('Temp', 'temp@test.com', 0)");
    let count_before: str = mysql_query_scalar(fd, "SELECT COUNT(*) FROM test_users");

    let rb_r: str = mysql_rollback(fd);
    if (!mysql_is_error(rb_r)) {
        test_pass("rollback");
    } else {
        test_fail("rollback", mysql_error_msg(rb_r));
        fails = fails + 1;
    }

    let count_after: str = mysql_query_scalar(fd, "SELECT COUNT(*) FROM test_users");
    if (count_after == "3") {
        test_pass("rollback restored count to 3");
    } else {
        test_fail("rollback count", "before=" + count_before + " after=" + count_after);
        fails = fails + 1;
    }

    // DELETE
    print_raw("\n--- DELETE ---\n");
    let del: str = mysql_query(fd, "DELETE FROM test_users WHERE age = 99");
    if (mysql_is_ok(del)) {
        test_pass("delete");
    } else {
        test_fail("delete", mysql_error_msg(del));
        fails = fails + 1;
    }

    // Error handling
    print_raw("\n--- Error Handling ---\n");
    let bad: str = mysql_query(fd, "SELECT * FROM nonexistent_table_xyz");
    if (mysql_is_error(bad)) {
        test_pass("error detected for bad query");
        let ecode: i32 = mysql_error_code(bad);
        if (ecode > 0) {
            test_pass("error_code = " + i32_to_str(ecode));
        } else {
            test_fail("error_code", i32_to_str(ecode));
            fails = fails + 1;
        }
        let emsg: str = mysql_error_msg(bad);
        if (len(emsg) > 0) {
            test_pass("error_msg: " + emsg);
        } else {
            test_fail("error_msg", "empty");
            fails = fails + 1;
        }
    } else {
        test_fail("error detect", "no error for bad query");
        fails = fails + 1;
    }

    // Cleanup
    print_raw("\n--- Cleanup ---\n");
    mysql_query(fd, "DROP TABLE IF EXISTS test_users");
    test_pass("cleanup");

    // Close
    mysql_close(fd);
    test_pass("close");

    print_raw("\n");
    if (fails > 0) {
        print(i32_to_str(fails) + " test(s) FAILED");
        return 1;
    }
    print("All tests PASSED");
    return 0;
}
