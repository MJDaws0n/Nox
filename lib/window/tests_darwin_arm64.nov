    fails = fails + assert_eq_str("escape backslash", wm_escape_arg("a\\b"), "a\\\\b");
    fails = fails + assert_eq_str("escape newline", wm_escape_arg("a\nb"), "a\\nb");
    fails = fails + assert_eq_str("unescape plain", wm_unescape_arg("hello"), "hello");
    fails = fails + assert_eq_str("unescape backslash", wm_unescape_arg("a\\\\b"), "a\\b");
    fails = fails + assert_eq_str("unescape newline", wm_unescape_arg("a\\nb"), "a\nb");

