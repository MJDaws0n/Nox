    fails = fails + assert_eq_i32("wm_to_u8(256)", wm_to_u8(256), 0);
    fails = fails + assert_eq_i32("wm_to_u8(-1)", wm_to_u8(-1), 255);

    // ── wm_escape_arg / wm_unescape_arg ──
