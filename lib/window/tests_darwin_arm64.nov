    fails = fails + assert_eq_i32("parse PORT 8080", wm_parse_port("PORT 8080"), 8080);
    fails = fails + assert_eq_i32("parse PORT 3000", wm_parse_port("PORT 3000"), 3000);
    fails = fails + assert_eq_i32("parse invalid", wm_parse_port("ERR"), -1);

    // ── wm_syscall0 (assembly: mov + syscall + getreg) ──
    print_raw("\n--- Syscall wrappers ---\n");
    let pid_raw: u64 = wm_syscall0(20);  // SYS_getpid
    fails = fails + assert_true("wm_syscall0 getpid > 0", pid_raw > 0);

    // ── wm_socket (assembly: syscall socket AF_UNIX) ──
    print_raw("\n--- Unix Socket ---\n");
    let sock: i32 = wm_socket();
    fails = fails + assert_true("wm_socket >= 0", sock >= 0);
    if (sock >= 0) {
