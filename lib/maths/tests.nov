fn test_pass(name: str) -> void {
    print_raw("  [PASS] " + name + "\n");
}

fn test_fail(name: str, detail: str) -> void {
    print_raw("  [FAIL] " + name + ": " + detail + "\n");
}

fn assert_eq_i32(name: str, got: i32, expected: i32) -> i32 {
    if (got == expected) { test_pass(name); return 0; }
    test_fail(name, "got " + i32_to_str(got) + ", expected " + i32_to_str(expected));
    return 1;
}

fn assert_eq_i64(name: str, got: i64, expected: i64) -> i32 {
    if (got == expected) { test_pass(name); return 0; }
    test_fail(name, "got " + i64_to_str(got) + ", expected " + i64_to_str(expected));
    return 1;
}

fn assert_eq_str(name: str, got: str, expected: str) -> i32 {
    if (str_equals(got, expected)) { test_pass(name); return 0; }
    test_fail(name, "got '" + got + "', expected '" + expected + "'");
    return 1;
}

fn assert_true(name: str, val: bool) -> i32 {
    if (val) { test_pass(name); return 0; }
    test_fail(name, "expected true");
    return 1;
}

fn assert_gt_i32(name: str, val: i32, threshold: i32) -> i32 {
    if (val > threshold) { test_pass(name); return 0; }
    test_fail(name, "expected > " + i32_to_str(threshold));
    return 1;
}

fn assert_gt_i64(name: str, val: i64, threshold: i64) -> i32 {
