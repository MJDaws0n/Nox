// ---------------------------------------------------------------------------
// maths/core - mathematical functions (cross-platform, no assembly)
// ---------------------------------------------------------------------------

module maths_core;

// ---------------------------------------------------------------------------
// Parity & primality
// ---------------------------------------------------------------------------

fn is_even(n: i32) -> bool {
    return (n % 2) == 0;
}

fn is_odd(n: i32) -> bool {
    return (n % 2) != 0;
}

fn is_prime(n: i32) -> bool {
    if (n <= 1) { return false; }
    if (n == 2) { return true; }
    if ((n % 2) == 0) { return false; }
    let i: i32 = 3;
    while (i <= (n / i)) {
        if ((n % i) == 0) { return false; }
        i = i + 2;
    }
    return true;
}

// ---------------------------------------------------------------------------
// Absolute value
// ---------------------------------------------------------------------------

fn abs(x: i32) -> i32 {
    if (x < 0) { return 0 - x; }
    return x;
}

fn abs64(x: i64) -> i64 {
    if (x < 0) { return 0 - x; }
    return x;
}

// ---------------------------------------------------------------------------
// Min / Max / Clamp
// ---------------------------------------------------------------------------

fn max(a: i32, b: i32) -> i32 {
    if (a > b) { return a; }
    return b;
}

fn min(a: i32, b: i32) -> i32 {
    if (a < b) { return a; }
    return b;
}

fn clamp(val: i32, lo: i32, hi: i32) -> i32 {
    if (val < lo) { return lo; }
    if (val > hi) { return hi; }
    return val;
}

fn max64(a: i64, b: i64) -> i64 {
    if (a > b) { return a; }
    return b;
}

fn min64(a: i64, b: i64) -> i64 {
    if (a < b) { return a; }
    return b;
}

fn clamp64(val: i64, lo: i64, hi: i64) -> i64 {
    if (val < lo) { return lo; }
    if (val > hi) { return hi; }
    return val;
}

// ---------------------------------------------------------------------------
// Sign
// ---------------------------------------------------------------------------

fn sign(x: i32) -> i32 {
    if (x > 0) { return 1; }
    if (x < 0) { return 0 - 1; }
    return 0;
}

fn sign64(x: i64) -> i64 {
    if (x > 0) { return 1; }
    if (x < 0) { return 0 - 1; }
    return 0;
}

// ---------------------------------------------------------------------------
// Power (integer exponentiation)
// ---------------------------------------------------------------------------

fn pow_i32(base: i32, exp: i32) -> i32 {
    if (exp < 0) { return 0; }
    if (exp == 0) { return 1; }
    let result: i32 = 1;
    let i: i32 = 0;
    while (i < exp) {
        result = result * base;
        i = i + 1;
    }
    return result;
}

fn pow_i64(base: i64, exp: i32) -> i64 {
    if (exp < 0) { return 0; }
    if (exp == 0) { return 1; }
    let result: i64 = 1;
    let i: i32 = 0;
    while (i < exp) {
        result = result * base;
        i = i + 1;
    }
    return result;
}

// ---------------------------------------------------------------------------
// Factorial
// ---------------------------------------------------------------------------

fn factorial(n: i32) -> i64 {
    if (n <= 1) { return 1; }
    let result: i64 = 1;
    let i: i32 = 2;
    while (i <= n) {
        result = result * i;
        i = i + 1;
    }
    return result;
}

// ---------------------------------------------------------------------------
// GCD / LCM
// ---------------------------------------------------------------------------

fn gcd(a: i32, b: i32) -> i32 {
    if (a < 0) { a = 0 - a; }
    if (b < 0) { b = 0 - b; }
    while (b != 0) {
        let t: i32 = b;
        b = a % b;
        a = t;
    }
    return a;
}

fn lcm(a: i32, b: i32) -> i32 {
    if (a == 0 || b == 0) { return 0; }
    let g: i32 = gcd(a, b);
    let aa: i32 = a;
    if (aa < 0) { aa = 0 - aa; }
    let bb: i32 = b;
    if (bb < 0) { bb = 0 - bb; }
    return (aa / g) * bb;
}

// ---------------------------------------------------------------------------
// Integer division (ceiling)
// ---------------------------------------------------------------------------

fn div_ceil(a: i32, b: i32) -> i32 {
    if (b == 0) { return 0; }
    let d: i32 = a / b;
    let r: i32 = a % b;
    if (r != 0 && ((a > 0 && b > 0) || (a < 0 && b < 0))) {
        d = d + 1;
    }
    return d;
}

// ---------------------------------------------------------------------------
// Wrap value into range [0, max)
// ---------------------------------------------------------------------------

fn wrap(val: i32, max_val: i32) -> i32 {
    if (max_val <= 0) { return 0; }
    let r: i32 = val % max_val;
    if (r < 0) { r = r + max_val; }
    return r;
}

// ---------------------------------------------------------------------------
// Map value from one range to another
// ---------------------------------------------------------------------------

fn map_range(val: i32, in_min: i32, in_max: i32, out_min: i32, out_max: i32) -> i32 {
    if (in_max == in_min) { return out_min; }
    return out_min + (val - in_min) * (out_max - out_min) / (in_max - in_min);
}

// ---------------------------------------------------------------------------
// Integer square root (floor)
// ---------------------------------------------------------------------------

fn isqrt(n: i32) -> i32 {
    if (n < 0) { return 0; }
    if (n == 0) { return 0; }
    let x: i32 = n;
    let y: i32 = (x + 1) / 2;
    while (y < x) {
        x = y;
        y = (x + n / x) / 2;
    }
    return x;
}

// ---------------------------------------------------------------------------
// Fibonacci
// ---------------------------------------------------------------------------

fn fibonacci(n: i32) -> i64 {
    if (n <= 0) { return 0; }
    if (n == 1) { return 1; }
    let a: i64 = 0;
    let b: i64 = 1;
    let i: i32 = 2;
    while (i <= n) {
        let tmp: i64 = a + b;
        a = b;
        b = tmp;
        i = i + 1;
    }
    return b;
}

// ---------------------------------------------------------------------------
// Sum of digits
// ---------------------------------------------------------------------------

fn digit_sum(n: i32) -> i32 {
    let x: i32 = n;
    if (x < 0) { x = 0 - x; }
    let s: i32 = 0;
    while (x > 0) {
        s = s + (x % 10);
        x = x / 10;
    }
    return s;
}

// ---------------------------------------------------------------------------
// Count digits
// ---------------------------------------------------------------------------

fn digit_count(n: i32) -> i32 {
    if (n == 0) { return 1; }
    let x: i32 = n;
    if (x < 0) { x = 0 - x; }
    let c: i32 = 0;
    while (x > 0) {
        c = c + 1;
        x = x / 10;
    }
    return c;
}

// ---------------------------------------------------------------------------
// Lerp (integer linear interpolation, t in [0, 100])
// ---------------------------------------------------------------------------

fn lerp(a: i32, b: i32, t: i32) -> i32 {
    return a + (b - a) * t / 100;
}
